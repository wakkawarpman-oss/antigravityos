      "targets": [
        {
          "expr": "100 * rate(discovery_engine_validate_ok[5m]) / clamp_min(rate(discovery_engine_raw_hits[5m]), 1)",
          "legendFormat": "validate_rate",
          "refId": "A"
        }
      ],
      "title": "Validation Rate %",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 3,
      "options": {
        "legend": {
          "calcs": ["lastNotNull"],
          "displayMode": "table",
          "placement": "right"
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "targets": [
        {
          "expr": "increase(discovery_engine_rejected_fp[1h])",
          "legendFormat": "rejected_fp",
          "refId": "A"
        },
        {
          "expr": "increase(discovery_engine_dedup_hits[1h])",
          "legendFormat": "dedup_hits",
          "refId": "B"
        }
      ],
      "title": "Quality Counters (1h)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI}"
      },
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 0,
        "y": 6
      },
      "id": 4,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "expr": "{job=\"hanna\"} |= \"INVALID_SCHEMA\" or {job=\"hanna\"} |= \"ADAPTER_FAIL\"",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Adapter Errors (Live Logs)",
      "type": "logs"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "align": "auto"
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 12,
        "y": 6
      },
      "id": 5,
      "options": {
        "cellHeight": "sm",
        "footer": {
          "countRows": false,
          "fields": "",
          "reducer": [
            "sum"
          ],
          "show": false
        },
        "showHeader": true
      },
      "targets": [
        {
          "expr": "topk(5, sum by(adapter) (count_over_time({job=\"hanna\"} |= \"ADAPTER_FAIL\" [5m])))",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Top Failing Adapters (5m)",
      "transformations": [
        {
          "id": "labelsToFields",
          "options": {
            "mode": "columns"
          }
        }
      ],
      "type": "table"
    }
